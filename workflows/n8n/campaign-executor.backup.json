    {
      "parameters": {
        "jsCode": "// Extract messages from current batch\nconst batch = $('Loop Batches').item.json;\nconst messages = batch.messages || [];\n\n// Return each message as separate item for processing\nreturn messages.map(msg => ({\n  json: {\n    ...msg,\n    campaignId: batch.campaignId,\n    instanceName: batch.instanceName,\n    messageDelay: batch.messageDelay,\n    batchIndex: batch.batchIndex,\n    totalBatches: batch.totalBatches\n  }\n}));"
      },
