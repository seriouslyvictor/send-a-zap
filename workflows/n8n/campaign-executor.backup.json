      "parameters": {
        "jsCode": "// Campaign was paused or cancelled during execution\nconst campaignId = $('Webhook Trigger').item.json.campaignId;\nconst currentStatus = $('Check Status In Loop').item.json.status;\n\nconsole.log(`Campaign ${campaignId} is now ${currentStatus}, stopping execution`);\n\nreturn [{\n  json: {\n    campaignId,\n    status: currentStatus,\n    message: `Campaign execution stopped - status changed to ${currentStatus}`\n  }\n}];"
