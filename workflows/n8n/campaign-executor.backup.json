    {
      "parameters": {
        "jsCode": "// Get campaign config from webhook trigger\nconst config = $('Webhook Trigger').item.json;\nconst batchSize = config.batchSize || 50;\nconst messages = $input.all();\n\n// Split messages into batches\nconst batches = [];\nfor (let i = 0; i < messages.length; i += batchSize) {\n  batches.push({\n    batchIndex: Math.floor(i / batchSize),\n    messages: messages.slice(i, i + batchSize).map(m => m.json),\n    totalBatches: Math.ceil(messages.length / batchSize),\n    totalMessages: messages.length,\n    campaignId: config.campaignId,\n    instanceName: config.instanceName || 'whatsapp-main',\n    messageDelay: config.messageDelay || 2,\n    batchDelay: config.batchDelay || 30,\n    autoRetry: config.autoRetry || false,\n    maxRetries: config.maxRetries || 3\n  });\n}\n\n// If no messages, return empty batch to handle completion\nif (batches.length === 0) {\n  return [{\n    json: {\n      batchIndex: 0,\n      messages: [],\n      totalBatches: 0,\n      totalMessages: 0,\n      campaignId: config.campaignId,\n      instanceName: config.instanceName || 'whatsapp-main',\n      messageDelay: config.messageDelay || 2,\n      batchDelay: config.batchDelay || 30,\n      noMessages: true\n    }\n  }];\n}\n\nreturn batches.map(batch => ({ json: batch }));"
      },
      "id": "split-into-batches",
      "name": "Split Into Batches",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 200]
    },
    {
