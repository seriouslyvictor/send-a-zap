    {
      "parameters": {
        "jsCode": "let status;\n\nswitch ($input.first().json.status) {\n  case \"SERVER_ACK\":\n    status = 'SENT';\n    break;\n  case \"DELIVERY_ACK\":\n    status = 'DELIVERED';\n    break;\n  case \"READ\":\n    status = 'READ';\n    break;\n  default:\n    status = 'UNKNOWN';\n}\n\nreturn [{\n  json: {\n    provider_message_id: $input.first().json.message_id,\n    status,\n    provider_status_code: $input.first().json.status\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
