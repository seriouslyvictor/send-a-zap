# ===================================================================
# Environment Variables for WhatsApp Automation Stack
# ===================================================================
# Copy this to .env and fill in all values before deployment
# NEVER commit .env to version control!
# ===================================================================

# ===================================================================
# DEPLOYMENT CONTEXT
# ===================================================================
# Deployment environment: development, staging, production
ENVIRONMENT=production

# Compose project name (used for container prefixing)
COMPOSE_PROJECT_NAME=whatsapp

# Timezone for all services
TIMEZONE=America/Sao_Paulo

# ===================================================================
# POSTGRESQL DATABASE
# ===================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=whatsapp_automation
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200

# ===================================================================
# REDIS CACHE
# ===================================================================
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# ===================================================================
# n8n WORKFLOW ENGINE
# ===================================================================
N8N_VERSION=latest
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https

# IMPORTANT: Change these credentials!
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# n8n Encryption key (generate a random string, min 32 chars)
# Linux: openssl rand -base64 32
# Windows PowerShell: [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString()))
N8N_ENCRYPTION_KEY=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING

# n8n Database
N8N_DB_NAME=n8n

# n8n Webhooks (set to your COOLIFY domain)
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/

# n8n API Key (for external integrations)
N8N_API_KEY=CHANGE_THIS_TO_SECURE_API_KEY

# ===================================================================
# EVOLUTION API (WhatsApp Integration)
# ===================================================================
EVOLUTION_API_IMAGE=evoapicloud/evolution-api:latest
EVOLUTION_SERVER_NAME=Evolution
EVOLUTION_SERVER_TYPE=http
EVOLUTION_PORT=8080
EVOLUTION_API_KEY=CHANGE_THIS_TO_SECURE_API_KEY

# IMPORTANT: Set this to your COOLIFY domain
EVOLUTION_SERVER_URL=https://api.yourdomain.com

# Webhooks
EVOLUTION_WEBHOOK_URL=https://yourdomain.com/api/webhooks/evolution
EVOLUTION_WEBHOOK_SECRET=CHANGE_THIS_TO_RANDOM_WEBHOOK_SECRET

# Database (will use PostgreSQL from POSTGRES_* vars above)
EVOLUTION_DATABASE_PROVIDER=postgres

# Logging
EVOLUTION_LOG_LEVEL=info

# CORS Settings
EVOLUTION_CORS_ORIGIN=https://yourdomain.com
EVOLUTION_CORS_METHODS=GET,POST,PUT,DELETE,PATCH
EVOLUTION_CORS_CREDENTIALS=true

# Language & Timezone
EVOLUTION_LANGUAGE=pt-BR

# ===================================================================
# NEXT.JS FRONTEND
# ===================================================================
NEXTJS_IMAGE=whatsapp-automation:latest
NEXTJS_PORT=3000

# Read-only BullMQ dashboard (served by the worker at /queues)
# Keep the default loopback bind unless the worker container is attached only
# to Docker's internal network. Never publish this port or add a proxy route.
QUEUE_DASHBOARD_HOST=127.0.0.1
QUEUE_DASHBOARD_PORT=3001
QUEUE_DASHBOARD_USERNAME=admin
QUEUE_DASHBOARD_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_PASSWORD

# ===================================================================
# APPLICATION INTEGRATION
# ===================================================================
# Base URLs for internal service communication
# These should use container names (they're on the same Docker network)
N8N_INTERNAL_URL=http://n8n:5678
EVOLUTION_API_INTERNAL_URL=http://evolution-api:8080

# Public URLs (used by frontend and webhooks)
# These should be your COOLIFY domain URLs
NEXTJS_PUBLIC_N8N_URL=https://n8n.yourdomain.com
NEXTJS_PUBLIC_API_URL=https://api.yourdomain.com
NEXTJS_PUBLIC_APP_URL=https://app.yourdomain.com

# ===================================================================
# SECURITY & SECRETS
# ===================================================================
# All API keys and passwords MUST be stored as COOLIFY secrets
# They should NOT be in .env for production
# In COOLIFY dashboard: Settings → Secrets → Add secret

# Example secret names to add in COOLIFY:
# - POSTGRES_PASSWORD
# - N8N_BASIC_AUTH_PASSWORD
# - N8N_ENCRYPTION_KEY
# - N8N_API_KEY
# - EVOLUTION_API_KEY
# - QUEUE_DASHBOARD_PASSWORD

# ===================================================================
# NOTES FOR COOLIFY DEPLOYMENT
# ===================================================================
# 1. Generate secure passwords and keys before deployment:
#    - Use strong, random passwords (20+ characters)
#    - Store all secrets in COOLIFY's secret manager
#    - Never hardcode secrets in .env
#
# 2. Update domain names:
#    - Replace "yourdomain.com" with your actual domain
#    - Ensure DNS records point to your VPS
#
# 3. SSL/HTTPS:
#    - COOLIFY handles SSL automatically
#    - All public endpoints should use https://
#
# 4. Health checks:
#    - All services have built-in health checks
#    - COOLIFY will monitor and auto-restart if needed
#
# 5. Database setup:
#    - First deployment will initialize databases
#    - Subsequent deployments will not reinitialize
#    - Run migrations manually if needed:
#      docker exec whatsapp_nextjs npx prisma migrate deploy
#
# 6. Backup strategy:
#    - COOLIFY can back up volumes automatically
#    - Configure in COOLIFY UI under Backups
#    - Especially important for postgres_data and evolution_instances
