# ===================================================================
# WhatsApp Automation - Unified Environment Configuration
# ===================================================================
# SECURITY WARNING: NEVER commit .env to git!
# Copy this file to .env and fill in your actual values.
#
# For Docker: cp .env.example .env
# For local dev: cp .env.example .env.local
# ===================================================================

# ===================================================================
# PostgreSQL Configuration (Shared by all services)
# ===================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=whatsapp_automation

# ===================================================================
# pgAdmin Configuration
# ===================================================================
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# ===================================================================
# n8n Configuration
# ===================================================================
# Basic Authentication (set to true to enable login)
N8N_BASIC_AUTH_ACTIVE=false
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD

# Webhook URL (use your domain in production)
N8N_WEBHOOK_URL=http://localhost:5678/

# Timezone
TIMEZONE=America/Sao_Paulo

# ===================================================================
# Evolution API Configuration
# ===================================================================
# Evolution API reads its own .env from ./api/.env
# Make sure to configure ./api/.env separately!

# Evolution API URL (Docker: http://whatsapp_evolution:8080 | Local: http://localhost:8080)
EVOLUTION_API_URL=http://localhost:8080

# ===================================================================
# Next.js API Keys (SERVER-SIDE ONLY - SAFE)
# ===================================================================
# These are used by Next.js API routes to communicate with services

# n8n API Key (generate a random key)
N8N_API_KEY=CHANGE_ME_GENERATE_RANDOM_KEY_HERE

# Evolution API Key (must match the one in ./api/.env)
EVOLUTION_API_KEY=CHANGE_ME_MATCH_WITH_API_ENV

# ===================================================================
# Optional: Next.js Public Variables (EXPOSED TO BROWSER)
# ===================================================================
# Only use NEXT_PUBLIC_ prefix for non-sensitive public config

# NEXT_PUBLIC_APP_NAME=WhatsApp Automation
# NEXT_PUBLIC_API_VERSION=1.0.0

# ===================================================================
# Evolution API Configuration
# ===================================================================
# Server Configuration
EVOLUTION_SERVER_NAME=evolution
EVOLUTION_SERVER_TYPE=http
EVOLUTION_SERVER_PORT=8080
EVOLUTION_SERVER_URL=http://whatsapp_evolution:8080

# Database Configuration
# Note: Uses the shared PostgreSQL database with its own schema
# The connection URI automatically uses POSTGRES_USER and POSTGRES_PASSWORD
EVOLUTION_DATABASE_PROVIDER=postgresql
EVOLUTION_DATABASE_CONNECTION_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/evolution?schema=evolution_api
EVOLUTION_DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

# Data to Save in Database
EVOLUTION_DATABASE_SAVE_DATA_INSTANCE=true
EVOLUTION_DATABASE_SAVE_DATA_NEW_MESSAGE=true
EVOLUTION_DATABASE_SAVE_MESSAGE_UPDATE=true
EVOLUTION_DATABASE_SAVE_DATA_CONTACTS=true
EVOLUTION_DATABASE_SAVE_DATA_CHATS=true
EVOLUTION_DATABASE_SAVE_DATA_LABELS=true
EVOLUTION_DATABASE_SAVE_DATA_HISTORIC=true
EVOLUTION_DATABASE_SAVE_IS_ON_WHATSAPP=true
EVOLUTION_DATABASE_SAVE_IS_ON_WHATSAPP_DAYS=7
EVOLUTION_DATABASE_DELETE_MESSAGE=true

# Cache Configuration (Uses shared Redis)
EVOLUTION_CACHE_REDIS_ENABLED=true
EVOLUTION_CACHE_REDIS_URI=redis://redis:6379/6
EVOLUTION_CACHE_REDIS_TTL=604800
EVOLUTION_CACHE_REDIS_PREFIX_KEY=evolution
EVOLUTION_CACHE_REDIS_SAVE_INSTANCES=false
EVOLUTION_CACHE_LOCAL_ENABLED=false

# Authentication
EVOLUTION_AUTHENTICATION_API_KEY=${EVOLUTION_API_KEY}
EVOLUTION_AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# Logging
EVOLUTION_LOG_LEVEL=ERROR,WARN,DEBUG,INFO,LOG,VERBOSE,DARK,WEBHOOKS,WEBSOCKET
EVOLUTION_LOG_COLOR=true
EVOLUTION_LOG_BAILEYS=error

# Session Configuration
EVOLUTION_CONFIG_SESSION_PHONE_CLIENT=Evolution API
EVOLUTION_CONFIG_SESSION_PHONE_NAME=Chrome
EVOLUTION_CONFIG_SESSION_PHONE_VERSION=2.3000.1030825052

# QR Code Configuration
EVOLUTION_QRCODE_LIMIT=30
EVOLUTION_QRCODE_COLOR='#175197'

# CORS Settings
EVOLUTION_CORS_ORIGIN=*
EVOLUTION_CORS_METHODS=GET,POST,PUT,DELETE
EVOLUTION_CORS_CREDENTIALS=true

# Instance Settings
EVOLUTION_DEL_INSTANCE=false
EVOLUTION_EVENT_EMITTER_MAX_LISTENERS=50

# Telemetry
EVOLUTION_TELEMETRY_ENABLED=true
EVOLUTION_TELEMETRY_URL=

# Language
EVOLUTION_LANGUAGE=pt-br

# Webhook Configuration
EVOLUTION_WEBHOOK_GLOBAL_ENABLED=false
EVOLUTION_WEBHOOK_GLOBAL_URL=''
EVOLUTION_WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# Webhook Events (all key events enabled by default)
EVOLUTION_WEBHOOK_EVENTS_QRCODE_UPDATED=true
EVOLUTION_WEBHOOK_EVENTS_MESSAGES_UPSERT=true
EVOLUTION_WEBHOOK_EVENTS_MESSAGES_UPDATE=true
EVOLUTION_WEBHOOK_EVENTS_MESSAGES_DELETE=true
EVOLUTION_WEBHOOK_EVENTS_SEND_MESSAGE=true
EVOLUTION_WEBHOOK_EVENTS_CONNECTION_UPDATE=true

# Webhook Retry Configuration
EVOLUTION_WEBHOOK_REQUEST_TIMEOUT_MS=60000
EVOLUTION_WEBHOOK_RETRY_MAX_ATTEMPTS=10
EVOLUTION_WEBHOOK_RETRY_INITIAL_DELAY_SECONDS=5
EVOLUTION_WEBHOOK_RETRY_USE_EXPONENTIAL_BACKOFF=true

# WhatsApp Business API
EVOLUTION_WA_BUSINESS_TOKEN_WEBHOOK=evolution
EVOLUTION_WA_BUSINESS_URL=https://graph.facebook.com
EVOLUTION_WA_BUSINESS_VERSION=v20.0
EVOLUTION_WA_BUSINESS_LANGUAGE=en_US

# Integrations (All Disabled by Default)
EVOLUTION_TYPEBOT_ENABLED=false
EVOLUTION_CHATWOOT_ENABLED=false
EVOLUTION_OPENAI_ENABLED=false
EVOLUTION_DIFY_ENABLED=false
EVOLUTION_N8N_ENABLED=false
EVOLUTION_EVOAI_ENABLED=false

# Message Queues (All Disabled)
EVOLUTION_RABBITMQ_ENABLED=false
EVOLUTION_SQS_ENABLED=false
EVOLUTION_KAFKA_ENABLED=false

# Websocket (Disabled)
EVOLUTION_WEBSOCKET_ENABLED=false
EVOLUTION_WEBSOCKET_GLOBAL_EVENTS=false

# S3 Storage (Disabled)
EVOLUTION_S3_ENABLED=false

# Prometheus Metrics (Disabled)
EVOLUTION_PROMETHEUS_METRICS=false

# ===================================================================
# How to Generate Secure Random Keys
# ===================================================================
#
# Linux/Mac:
#   openssl rand -hex 32
#
# Windows PowerShell:
#   [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# Or use any password generator with 32+ characters
# ===================================================================
