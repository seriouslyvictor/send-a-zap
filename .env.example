# Shared PostgreSQL as reached by host-side setup commands. The compose file
# uses host.docker.internal for the same server from inside its containers.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# n8n state and public callback URL.
N8N_ENCRYPTION_KEY=replace-with-a-random-32-character-or-longer-value
N8N_PUBLIC_URL=http://localhost:5678/

# Shared Evolution Go running on the development host.
EVOLUTION_API_URL=http://host.docker.internal:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:3000/api/webhooks/evolution
EVOLUTION_WEBHOOK_SECRET=replace-with-an-independent-random-secret

# Container timezone.
TIMEZONE=America/Sao_Paulo
